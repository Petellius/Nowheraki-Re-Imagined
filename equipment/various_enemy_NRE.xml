	<!-- NOTE: Don't change the name, it's hardcoded for RMG stuff -->
	<SuicideBomb name="Suicide Bomb" inventoryBinding="Armor"
			tooltip="@bombvest_name"
			img="data/models/equipment/suicide_vest_ui.dds"
			quantity="1"
			animationSet="suicide_bomb"
			soundUse="grenade_use"
		>
		<ModifiableParams
			changeInTime="0"
			changeOutTime="0"
		/>

		<Projectile
			bodyTemplate="InvisibleProjectile"

			soundExplosion="suicide_bomber_expl"

			friendlyFire="true"
			triggerOnImpact="true"

			physicsDetonationForce="100"
			audibleDetonationSoundRadius="40">

			<FX
				particles="SuicideExplosion"
				entity1="ExplosionLight"
				entity2="Blood Scorch Mark"
				randRotation2="true"
				entity3="FX_dust_large"
				deleteAfterMS3="35000"
			/>

			<EffectRange radiusMeters="2">
				<DamageEffect chancePercent="100" damage="700" damageType="2"/>
				<SuppressEffect amount="40"/>
				<SmokeEffect durationMSec="1000" />
			</EffectRange>
			<EffectRange radiusMeters="3">
				<DamageEffect chancePercent="100" damage="700" damageType="1"/>
				<SuppressEffect amount="40"/>
				<SmokeEffect durationMSec="1000" />
			</EffectRange>
			<EffectRange radiusMeters="3.7">
				<DamageEffect chancePercent="50" damage="15" damageType="1"/>
				<ScatterEffect chancePercent="100" />
				<SuppressEffect amount="10"/>
				<StunEffect chancePercent="100" innerRangeTimeMSec="350" outerRangeTimeMSec="130"/>
			</EffectRange>
			<EffectRange radiusMeters="6">
				<DamageEffect chancePercent="50" damage="10" damageType="1"/>
				<ScatterEffect chancePercent="100" />
				<StunEffect chancePercent="100" innerRangeTimeMSec="130" outerRangeTimeMSec="0"/>
			</EffectRange>
		</Projectile>
	</SuicideBomb>

	<Armor name="NRE Military SoftArmor" inventoryBinding="Armor" unlockCost="0"
			tooltip="@armor_enemy_softarmor_name"
			img="data/models/equipment/armor_softleveliiia_ui.dds"
		>
		<MobilityModifiers moveSpeedModifierPercent="0" turnSpeedModifierPercent="-5"/>

		<!--
		protectionArcDegrees: how wide around the trooper's origin the protection arc goes
		coveragePercent: which percent of the bullets go through (they deal 1 damage if bullet piercing < protectionLevel or full damage otherwise)
		piercingProtectionLevel: gets compared to the bullet's piercingLevel (recive 1 damage if > bulletPiercing and goes through CoveragePercent or normal damage otherwise)
		-->
		<Params>
			<ProtectionArc degrees="90" coveragePercent="40" piercingProtectionLevel="40"/>
			<ProtectionArc degrees="270" coveragePercent="20" piercingProtectionLevel="40"/>
			<ProtectionArc degrees="360" coveragePercent="40" piercingProtectionLevel="40"/>
		</Params>

		<RenderObject3D model="data/models/humans/attachments/chest_carrier_ultran_NGF.khm" diffuseTex="data/models/humans/attachments/chest_carrier_ultran_NGF.dds"/>
	</Armor>

	<Armor name="NRE Military HeavyArmor" inventoryBinding="Armor" unlockCost="0"
			tooltip="@armor_enemy_heavyarmor_name"
			img="data/models/equipment/armor_basic_ui.dds"
		>
		<MobilityModifiers moveSpeedModifierPercent="0" turnSpeedModifierPercent="-10"/>

		<!--
		protectionArcDegrees: how wide around the trooper's origin the protection arc goes
		coveragePercent: which percent of the bullets go through (they deal 1 damage if bullet piercing < protectionLevel or full damage otherwise)
		piercingProtectionLevel: gets compared to the bullet's piercingLevel (recive 1 damage if > bulletPiercing and goes through CoveragePercent or normal damage otherwise)
		-->
		<Params>
			<ProtectionArc degrees="90" coveragePercent="40" piercingProtectionLevel="50"/>
			<ProtectionArc degrees="270" coveragePercent="20" piercingProtectionLevel="40"/>
			<ProtectionArc degrees="360" coveragePercent="40" piercingProtectionLevel="50"/>
		</Params>

		<RenderObject3D model="data/models/humans/attachments/plate_carrier_mtn_NGF.khm" diffuseTex="data/models/humans/attachments/plate_carrier_mtn_NGF.dds"/>		
	</Armor>

