<Equipment>

	<Firearm name="Type 56 NWS Militia" inventoryBinding="PrimaryWeapon" category="militiarifle" unlockCost="0"
			tooltip="@firearm_type56cia_name"
			description="@firearm_type56nws_desc"
			img="data/models/weapons/type56_ui.dds"
			animationSet="rifle"
		>
		<MobilityModifiers moveSpeedModifierPercent="-4" turnSpeedModifierPercent="0"/>
		<ConcealmentModifier add="-2"/>
		<RenderObject3D model="data/models/weapons/type56.khm" attachSlot="prop_back_rifle" skipGOSSAO="true" diffuseTex="data/models/weapons/type56.dds"/>

		<ModifiableParams
			numPellets="1"
			roundsPerMagazine="30"
			closedBolt="1"
			suppressArea="1"

			cyclicReload="0"
			reloadTime="4000"
			reloadEmptyTime="4800"
			changeInTime="700"
			changeOutTime="700"
			readyTime="400"
			guardTime="200"

			accuracyStart="130"
			accuracyEnd="80"
			accuracyStartDist="0"
			accuracyEndDist="100"
		/>

		<Params
			caliberInfoText="@firearm_caliber_762x39_name"
			operationInfoText="@firearm_operation_semifull_name"
			ejectingShellEntity="BulletCasingLarge"
			magazineEntity="type56_mag"
			ai_rangeMin="1.0"
			ai_rangeOptimal="25.0"
			ai_rangeMax="100.0"
		/>

		<AttackTypes>
			<AttackType name="Militia_Rifle_Heavy_1" rangeMeters="5"/>
			<AttackType name="Militia_Rifle_Heavy_2" rangeMeters="12"/>
			<AttackType name="Militia_Rifle_Heavy_3" rangeMeters="22"/>
			<AttackType name="Militia_Rifle_Heavy_4" inCoverOverride="Militia_Rifle_Heavy_4_Mounted" rangeMeters="50"/>
			<AttackType name="Militia_Rifle_Heavy_5" rangeMeters="9999"/>
		</AttackTypes>

		<AttackTypesSuppressiveFire>
			<AttackType name="AreaSuppression_Militia_Rifle_Auto" rangeMeters="12"/>
			<AttackType name="AreaSuppression_Militia_Rifle_Long" rangeMeters="9999"/> 
		 </AttackTypesSuppressiveFire>

		<MuzzleFlash lightTemplate="ShotLightLarge" tracerTemplate="Tracer_Rifle">
			<Flare particles="FX_MUZZLE_FLASH_RIFLE_01" />
			<Flare particles="FX_MUZZLE_FLASH_RIFLE_02" />
			<Flare particles="FX_MUZZLE_FLASH_RIFLE_03" />
			<Flare particles="FX_MUZZLE_FLASH_RIFLE_04" />
		</MuzzleFlash>

		<Sounds> 
			<Equip name="rifle_eqp"/>
			<Unequip name="rifle_neqp"/>
			<Reload name="rifle_reld"/>
			<ReloadEmpty name="rifle_reldempt"/>
			<Fire name="type56_fire"/>
			<ShellDrop name="rifle_shell_drop"/>
			<Empty name="gen_empty"/>
		</Sounds>
	</Firearm>
	
</Equipment>
