<!-- HELP
	Each Group represents a particular enemy distribution, chosen at random for each map
	The map generator will pick enemy classes from the group to reach a desired total danger score
		based on the difficulty setting and the number of troopers on the map
	The "danger" setting tells the map generator how difficult that particular enemy is to deal with
	The "weightChance" controls the relative distribution of the enemies in the group
		Ex. Troop A weight 10 and Troop B weight 5 you get twice as many A troops as B troops
	Setting higher weight to more dangerous troops will lower the overall number of enemies on the map, and vice-versa
-->

<RMGGroups>
	<Group name="NRE Default Mix" localizedName="@group_defaultmix">
		<Troop entity="Melee Guy" 					danger="4"	weightChance="1" />
		<Troop entity="Pistol Insurgent"			danger="8"	weightChance="5" />
		<Troop entity="Pistol Insurgent Weaponless"	danger="7"	weightChance="2" />
		<Troop entity="Grunt Insurgent"				danger="10"	weightChance="20" />
		<Troop entity="Veteran Insurgent"			danger="13"	weightChance="5" />
		<Troop entity="Veteran Insurgent LongRange"	danger="13"	weightChance="2" onlyOutside="true"/>

		<Troop entity="Foreign Advisor"				danger="17"	weightChance="5" />

		<Troop entity="Machinegunner"				danger="15"	weightChance="5" />

<!-- 		<Troop entity="Rocket Insurgent"		danger="18"	weightChance="2" /> --> 
		<Troop entity="Grunt + Rocket Insurgent"	danger="17"	weightChance="5" onlyOutside="true"/>
		<Troop entity="Sniper Insurgent"			danger="20"	weightChance="1" onlyOutside="true"/>

		<Troop entity="Suicide Bomber"				danger="15"	weightChance="2" />
		
		<Troop entity="Executioner"					danger="20"	weightChance="4" />
	</Group>
</RMGGroups>